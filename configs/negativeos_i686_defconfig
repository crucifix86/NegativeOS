# NegativeOS Buildroot config — i686 (32-bit)
# Run: make negativeos_i686_defconfig

# Architecture
BR2_i386=y
BR2_x86_i686=y
BR2_X86_CPU_HAS_MMX=y
BR2_X86_CPU_HAS_SSE=y

# Compiler flags for P4 compatibility
BR2_TARGET_OPTIMIZATION="-march=i686 -mtune=pentium4 -O2 -pipe"

# Toolchain
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
BR2_GCC_VERSION_14_X=y

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="i386"
BR2_LINUX_KERNEL_BZIMAGE=y

# Init
BR2_INIT_RUNIT=y
BR2_PACKAGE_RUNIT=y

# Core userspace
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_DOSFSTOOLS=y

# Bootloader — legacy BIOS only for i686 (P4 has no UEFI)
BR2_TARGET_GRUB2=y
BR2_TARGET_GRUB2_I386_PC=y

# Package manager
BR2_PACKAGE_APK_TOOLS=y

# Xorg + IceWM
BR2_PACKAGE_XORG7=y
BR2_PACKAGE_XSERVER_XORG_SERVER=y
BR2_PACKAGE_ICEWM=y
BR2_PACKAGE_SLIM=y

# Legacy GPU drivers for P4 era
BR2_PACKAGE_XDRIVER_XSERVER_XORG_VIDEO_VESA=y
BR2_PACKAGE_XDRIVER_XSERVER_XORG_VIDEO_SAVAGE=y

# Core apps
BR2_PACKAGE_PCMANFM=y
BR2_PACKAGE_RXVT_UNICODE=y
BR2_PACKAGE_MOUSEPAD=y
BR2_PACKAGE_GPICVIEW=y
BR2_PACKAGE_XARCHIVER=y

# Networking
BR2_PACKAGE_NETWORKMANAGER=y
BR2_PACKAGE_AVAHI=y
BR2_PACKAGE_SAMBA4=y

# Audio
BR2_PACKAGE_PIPEWIRE=y

# Browser
BR2_PACKAGE_PALEMOON=y

# Developer tools (for Claude Code + general dev)
BR2_PACKAGE_NODEJS=y
BR2_PACKAGE_GIT=y
BR2_PACKAGE_CURL=y
BR2_PACKAGE_OPENSSH=y

# Firmware
BR2_PACKAGE_LINUX_FIRMWARE=y
BR2_PACKAGE_NDISWRAPPER=y

# Build options
BR2_OPTIMIZE_2=y
BR2_STRIP_strip=y
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y

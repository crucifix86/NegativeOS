# NegativeOS IceWM preferences

# Taskbar
TaskBarShowClock=1
TaskBarShowMailboxStatus=0
TaskBarShowWorkspaces=1
TaskBarShowWindows=1
TaskBarShowCPUStatus=0
TaskBarClockFormat="%H:%M"

# Desktop
DesktopBackgroundImage="/usr/share/negativeos/wallpapers/wallpaper.png"
DesktopBackgroundScaled=1
DesktopBackgroundColor="#008080"

# Window behavior
FocusModel=ClickToFocus
ClickToFocus=1

# Start menu
ShowProgramsMenu=1
